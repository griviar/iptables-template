# Copy this file to user/.env and fill in server-specific values.
# WAN and WAN_IP are set automatically by detect-wan.sh

export WAN=eth0
export WAN_IP=1.2.3.4

# ── Required for 'gateway' tag only ──────────────────────────────────────────
# export LAN1=eth1
# export LAN1_IP_RANGE=10.1.3.0/24

# ── Required if using SSH whitelist (see user/custom.sh.example) ─────────────
# export PORT_SSH=2222

# ── Required if using APP port whitelist (see user/custom.sh.example) ────────
# export PORT_APP=8443
